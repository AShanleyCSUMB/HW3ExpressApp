<%- include('partials/header') %>
<%- include('partials/nav') %>

<main class="container">
  <h1>Welcome to Travel Explorer!</h1>
  <p>This site helps users explore country information and current weather.</p>
  <p><strong>Trip Code from node package:</strong> <%= tripCode %></p>

  <div class="card-grid">
    <section class="card">
      <h2>Search for a Country</h2>
      <p>Learn about a country's capital, region, population, and flag.</p>
      <a class="btn" href="/country">Go to Country Search</a>
    </section>

    <section class="card">
      <h2>Check the Weather</h2>
      <p>Enter a city to see the current temperature and conditions.</p>
      <a class="btn" href="/weather">Go to Weather</a>
    </section>
  </div>
</main>

<%- include('partials/footer') %>